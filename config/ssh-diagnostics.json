{
  "timeout_seconds": 20,
  "max_output_chars": 1200,
  "templates": {
    "systemd": [
      { "label": "service status", "cmd": "systemctl status {service} --no-pager -l" },
      { "label": "journal tail",   "cmd": "journalctl -u {service} -n 50 --no-pager --output=short-iso" }
    ],
    "docker": [
      { "label": "container state", "cmd": "docker ps -a --filter name={container} --format 'table {{.Names}}\\t{{.Status}}\\t{{.Ports}}'" },
      { "label": "container logs",  "cmd": "docker logs {container} --tail 50 2>&1" }
    ],
    "http": [
      { "label": "port check",      "cmd": "ss -tlnp | grep ':{port}' || echo 'no process on :{port}'" },
      { "label": "health probe",    "cmd": "curl -s -o /dev/null -w '%{http_code} connect=%{time_connect}s total=%{time_total}s' --max-time 5 http://localhost:{port}/health || true" }
    ],
    "general": [
      { "label": "system overview", "cmd": "uptime && echo '---' && free -h && echo '---' && df -h /" }
    ]
  },
  "var_rules": {
    "service":   "^[a-zA-Z0-9_\\-.@]{1,64}$",
    "container": "^[a-zA-Z0-9_\\-.]{1,64}$",
    "port":      "^[1-9][0-9]{0,4}$"
  }
}
