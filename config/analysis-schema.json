{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UptimeResilienceAnalysis",
  "description": "JSON schema for codex exec --output-schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["severity", "healthScore", "summary", "telegramMessage", "criticalIssues", "warnings", "actions", "detailedReport"],
  "properties": {
    "severity": {
      "type": "string",
      "enum": ["CRITICAL", "WARNING", "OK"],
      "description": "Overall system severity level"
    },
    "healthScore": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Overall health score 0-100"
    },
    "summary": {
      "type": "string",
      "maxLength": 500,
      "description": "Short summary (2-3 sentences)"
    },
    "criticalIssues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["monitor", "issue", "impact", "action"],
        "properties": {
          "monitor": { "type": "string" },
          "issue": { "type": "string", "maxLength": 300 },
          "impact": { "type": "string", "maxLength": 200 },
          "action": { "type": "string", "maxLength": 300 }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["monitor", "issue", "recommendation"],
        "properties": {
          "monitor": { "type": "string" },
          "issue": { "type": "string", "maxLength": 300 },
          "recommendation": { "type": "string", "maxLength": 300 }
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["priority", "description", "command"],
        "properties": {
          "priority": { "type": "string", "enum": ["HIGH", "MED", "LOW"] },
          "description": { "type": "string", "maxLength": 300 },
          "command": { "type": "string", "maxLength": 500 }
        }
      }
    },
    "telegramMessage": {
      "type": "string",
      "maxLength": 3800,
      "description": "Markdown message to send to Telegram"
    },
    "detailedReport": {
      "type": "string",
      "maxLength": 6000,
      "description": "Detailed technical report"
    }
  }
}
