# ============================================================
# Uptime Resilience Agent — Ortam Degiskenleri
# cp .env.example .env  →  doldurup kaydet
# .env dosyasini ASLA git'e ekleme!
# ============================================================

# ---- ZORUNLU ----

# Uptime Kuma instance URL
UPTIME_KUMA_URL=https://uptime.ornekdomain.com

# Telegram Bot Token (@BotFather'dan al)
TELEGRAM_BOT_TOKEN=123456789:AAF...

# Telegram Chat ID (kullanici, grup veya kanal)
# Kullanici ID: @userinfobot'a mesaj at
# Grup ID: Gruba @getidsbot ekle, grup ID'si negatif olur
TELEGRAM_CHAT_ID=123456789

# ---- UPTIME KUMA AUTH (onerilen) ----

# JWT Token — tum monitorlere erisim ve aksiyon alma icin (ONERILEN)
# Nasil alinir: node scripts/get-jwt-token.js <username> <password>
# Token expire olmuyor, bir kez almaniz yeterli.
UPTIME_KUMA_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT almak icin kullanici bilgileri (get-jwt-token.js scripti icin)
# Token aldiktan sonra bu satirlari silebilirsiniz
# UPTIME_KUMA_USERNAME=admin
# UPTIME_KUMA_PASSWORD=sifreniz

# ---- OPSIYONEL ----

# Timezone (default: UTC)
# Listesi: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# TIMEZONE=Europe/Istanbul

# Tekrar alert aralik suresi — saat cinsinden (default: 4)
# DOWN monitor icin kac saatte bir alert gonderilsin?
# ALERT_REPEAT_HOURS=4

# Severity bazli farkli Telegram kanalina eskalasyon (zorunlu degil)
# TELEGRAM_CRITICAL_CHAT_ID=-100123456789
# TELEGRAM_WARNING_CHAT_ID=-100987654321

# Codex CLI binary yolu (default: codex — PATH'de olmasi gerekir)
# CODEX_BIN=/usr/local/bin/codex
